# Copier ce fichier vers `.env`, puis remplacer les valeurs.
# Ne pas partager `.env`: il contient des identifiants personnels.
# Le fichier `.env` est ignoré par Git.

# ---- ACLED (https://developer.acleddata.com/) ----
email_address="votre_email_myACLED"
acled_password="votre_mot_de_passe_myACLED"

# ---- Copernicus CDS / ERA5 (https://cds.climate.copernicus.eu/) ----
# UID numérique visible dans votre profil CDS
cds_user="123456"
# Clé API visible dans votre profil CDS
cds_key="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
