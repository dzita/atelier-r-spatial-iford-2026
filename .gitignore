# =====================================================================
# .gitignore — Atelier IFORD × GDSG 2026
# =====================================================================

# ---- R / RStudio -----------------------------------------------------
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rproj.user/
# Note : le .Rproj racine est volontairement versionne pour que tout
# participant qui clone le repo ouvre le projet d'un double-clic.
.Rprofile

# ---- Quarto ----------------------------------------------------------
/_site/
/.quarto/
**/.quarto/
/_freeze/
**/_freeze/
*_files/
*_cache/
# HTML rendus localement (les sources .qmd font foi)
pedagogie/**/*.html

# ---- renv ------------------------------------------------------------
renv/library/
renv/local/
renv/staging/
renv/python/
renv/sandbox/

# ---- Gros datasets (à re-télécharger via _helpers/fetch_data.R) ------
*.tif
*.tiff
*.img
*.nc
*.hdf
*.zip
*.gz
*.tar
*.7z

# Shapefiles (laisser les .gpkg passer mais bloquer les .shp lourds)
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.sbx
*.sbn
*.qix

# ---- Données sensibles (DHS Program — licence interdit redistribution)
# Bloquer le pack DHS brut où qu'il soit, quel que soit le dossier
**/CM_2018_DHS/
**/DHS_MICS/CM*FL*
*.DTA
*.SAV
*.rar
# Mais AUTORISER explicitement les CSV extraits pédagogiques
# (produits par 00_extraire_dhs_pour_webr.R, ~quelques Mo seulement)
!pedagogie/_commons/data/dhs_cmr/
!pedagogie/_commons/data/dhs_cmr/**
!pedagogie/_commons/data/dhs_cmr/*.csv
!pedagogie/_commons/data/dhs_cmr/*.R

# ---- Sorties générées ------------------------------------------------
_outputs/
outputs/*.pdf
outputs/*.html
*.log

# ---- OS / éditeurs ---------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/
.idea/

# ---- Secrets ---------------------------------------------------------
.env
.env.local
*.pem
*.key
credentials*.json

# ---- Exceptions positives (à pousser malgré les règles ci-dessus) ----
!02_DATASETS_CAMEROUN/**/README*.md
!02_DATASETS_CAMEROUN/**/DATA_PROVENANCE.md
!02_DATASETS_CAMEROUN/**/.gitkeep
.Rproj.user
