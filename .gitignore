# =====================================================================
# .gitignore — Atelier IFORD × GDSG 2026
# =====================================================================

# ---- R / RStudio -----------------------------------------------------
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rproj.user/
# Note : le .Rproj racine est volontairement versionne pour que tout
# participant qui clone le repo ouvre le projet d'un double-clic.
.Rprofile

# ---- Quarto ----------------------------------------------------------
/_site/
/.quarto/
**/.quarto/
/_freeze/
**/_freeze/
*_files/
*_cache/
# HTML rendus localement (les sources .qmd font foi)
pedagogie/**/*.html

# ---- renv ------------------------------------------------------------
renv/library/
renv/local/
renv/staging/
renv/python/
renv/sandbox/

# ---- Gros datasets (à re-télécharger via _helpers/fetch_data.R) ------
*.tif
*.tiff
*.img
*.nc
*.hdf
*.zip
*.gz
*.tar
*.7z

# Shapefiles (laisser les .gpkg passer mais bloquer les .shp lourds)
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.sbx
*.sbn
*.qix

# ---- Données J8 : télédétection + EMSR772 (Edith Darin) -------------
# GHS-BUILT 15 tuiles ZIP (~300 Mo) + EMSR772 (~50 Mo) + Open Buildings (~100 Mo)
# + WorldPop 2024 (~25 Mo) = ~500 Mo total — TOUT en local, exclu Git.
**/jour_08_teledetection/cmr_pop_*.tif
**/jour_08_teledetection/GHS-BUILT/**
**/jour_08_teledetection/EMSR772_products/**
**/jour_08_teledetection/Open Buildings/**
!**/jour_08_teledetection/GHS-BUILT/.gitkeep
!**/jour_08_teledetection/EMSR772_products/.gitkeep
!**/jour_08_teledetection/Open Buildings/.gitkeep

# ---- Données J9 : ACLED + ERA5 (Edith Darin) ------------------------
# Le NetCDF ERA5 (~quelques Mo) reste en local — téléchargement via API CDS.
# Le CSV ACLED reste commité (léger, < 1 Mo) pour permettre le rendu offline.
**/jour_09_acled_era5/*.nc
!**/jour_09_acled_era5/ACLED*.csv
!**/jour_09_acled_era5/.env.example
# Le fichier .env doit JAMAIS être commité (contient les identifiants API)
**/jour_09_acled_era5/.env
.env

# ---- Données J7 : population à haute résolution (Edith Darin) -------
# Les rasters TIF WorldPop (3 × ~25 Mo) restent en local, hors repo.
# Les ZIP GHS-POP (7 × ~15 Mo) idem - trop lourd pour Git.
# Les CSV (admpop) + gpkg GADM + DATA_ECOLE.zip restent commités (légers).
**/jour_07_population/cmr_pop_*.tif
**/jour_07_population/GHS-POP/**
!**/jour_07_population/GHS-POP/.gitkeep
!**/jour_07_population/*.csv
!**/jour_07_population/*.gpkg
!**/jour_07_population/*shp.zip
!**/jour_07_population/DATA_ECOLE.zip

# ---- Données sensibles (DHS Program — licence interdit redistribution)
# Bloquer le pack DHS brut où qu'il soit, quel que soit le dossier
**/CM_2018_DHS/
**/DHS_MICS/CM*FL*
*.DTA
*.SAV
*.rar
# Mais AUTORISER explicitement les CSV extraits pédagogiques
# (produits par 00_extraire_dhs_pour_webr.R, ~quelques Mo seulement)
!pedagogie/_commons/data/dhs_cmr/
!pedagogie/_commons/data/dhs_cmr/**
!pedagogie/_commons/data/dhs_cmr/*.csv
!pedagogie/_commons/data/dhs_cmr/*.R

# ---- Sorties générées ------------------------------------------------
_outputs/
outputs/*.pdf
outputs/*.html
*.log

# ---- OS / éditeurs ---------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/
.idea/

# ---- Secrets ---------------------------------------------------------
.env
.env.local
*.pem
*.key
credentials*.json

# ---- Exceptions positives (à pousser malgré les règles ci-dessus) ----
!02_DATASETS_CAMEROUN/**/README*.md
!02_DATASETS_CAMEROUN/**/DATA_PROVENANCE.md
!02_DATASETS_CAMEROUN/**/.gitkeep
.Rproj.user
